# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=playflix

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# TMDB API (Get from https://www.themoviedb.org/settings/api)
